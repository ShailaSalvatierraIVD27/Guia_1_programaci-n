Algoritmo Ejercicio3
	Definir letra Como Caracter
	Escribir Sin Saltar "Digite una letra: "
	Leer letra
	
	Segun letra Hacer
		"A" O "a":
			Escribir "ESCELENTE"
		"B" O "b":
			Escribir "BUENO"
		"C" O "c":
			Escribir "REGULAR"
		"D" O "d":
			Escribir "DEFICIENTE"
		"F" O "f":
			Escribir "REPROBADO"
		De Otro Modo:
			Escribir "letra no valida!!!"
	Fin Segun
FinAlgoritmo
